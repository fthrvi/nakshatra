# Nakshatra meshd per-node config → install to ~/.nakshatra/meshd.env
# Every var must be defined (systemd drops unset ${TOKENS} from ExecStart).

# Which mesh this node belongs to (sticky identity of the swarm).
MESH_ID=prithvi-q8

# Model id this node serves now (single value; repeat the unit for more).
SERVING=prithvi-q8

# Drift-class fingerprint for the served model — peers MUST match to chain.
# Get it from the gauge:  python scripts/discovery/drift_gauge.py <full-model.gguf>
# Leave as "unset" only on a consumer-only node that serves nothing.
DRIFT_CLASS=rocm-gfx1201-unset

# This node's local gRPC worker (host:port) to expose to peers.
# EMPTY string  → consumer-only node (orchestrator/client; reaches peers' workers).
WORKER_ADDR=

# Advisory dial hint published in the listing (optional; transport still pins).
ENDPOINT_HINT=

# Publish/discover cadence (seconds).
REFRESH=30
